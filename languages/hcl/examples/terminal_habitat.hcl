HABITAT ARCHON_TERMINAL {
  VERSION "1.0.0"

  ENVIRONMENT {
    TEMPERATURE: COLLABORATIVE
    VISIBILITY: TRANSPARENT
    ACCESSIBILITY: OPEN
  }

  RESOURCES {
    COMPUTE: 1000
    STORAGE: 10000
    BANDWIDTH: 5000
  }

  CONSTRAINTS: SOVEREIGNTY_MAINTAINED, AUDIT_TRAIL_COMPLETE, SAFETY_CHECKS_ENABLED

  INHABITANTS: ARCHON, PEER_REVIEWERS, COMMUNITY_LIAISONS
}
