          "instances": ["CI/CD", "Infrastructure as Code", "GitOps", "SRE"],
          "properties": {"goal": "fast_reliable_delivery", "metrics": "DORA_metrics", "tools": "containers_orchestration_pipelines"}
        },
        {
          "concept": "Testing",
          "definition": "Verification and validation of software behavior",
          "instances": ["Unit Testing", "Integration Testing", "E2E Testing", "Property-Based Testing", "Mutation Testing"],
          "properties": {"pyramid": "unit_integration_e2e", "goal": "confidence_in_correctness", "automation": "CI_pipelines"}
        }
      ]
    },
    "data_science": {
      "concept": "Data Science",
      "definition": "Extracting knowledge and insights from structured and unstructured data",
      "children": [
        {
          "concept": "Data Engineering",
